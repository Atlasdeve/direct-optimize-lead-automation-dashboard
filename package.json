    "render:start": "prisma migrate deploy && next start -p ${PORT:-10000}",
    "render:worker": "prisma migrate deploy && tsx lib/scheduler.ts",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "imap:verify": "tsx scripts/verify-imap.ts",
    "emails:discover": "tsx scripts/discover-emails.ts",
    "replies:sync": "tsx scripts/sync-replies.ts",
    "smtp:verify": "tsx scripts/verify-smtp.ts",
    "scheduler": "tsx lib/scheduler.ts"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
