{
  "manifest_version": 2,
  "name": "Direct Optimize Lead Capture",
  "version": "1.0.0",
  "description": "Capture the current website as a Direct Optimize lead.",
  "browser_action": {
    "default_title": "Capture lead",
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "<all_urls>"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "lead-capture@directoptimize.com"
    }
  }
}
