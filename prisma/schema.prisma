generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String?  @unique
  name         String?
  phone        String?
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  clientProjects   ClientProject[] @relation("ClientProjects")
  assignedProjects ClientProject[] @relation("EmployeeProjects")
  workLogs         WorkLog[]       @relation("EmployeeWorkLogs")
  projectComments  ProjectComment[]
  callLogs         CallLog[]
  notifications    Notification[] @relation("UserNotifications")

  @@map("users")
}

model Region {
  id        String   @id @default(cuid())
  name      String   @unique
  country   String
  timezone  String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  leads     Lead[]

  @@map("regions")
}

model Lead {
  id                 String    @id @default(cuid())
  companyName        String    @map("company_name")
  region             String
  country            String
  city               String?
  category           String?
  businessType       String?   @map("business_type")
  website            String?
  googleMapsUrl      String?   @map("google_maps_url")
  phone              String?
  email              String?
  whatsappAvailable  Boolean   @default(false) @map("whatsapp_available")
  whatsappStatus     String    @default("unknown") @map("whatsapp_status")
  ownerName          String?   @map("owner_name")
  ceoName            String?   @map("ceo_name")
  managerName        String?   @map("manager_name")
  linkedinUrl        String?   @map("linkedin_url")
  sourcePlatform     String    @default("google_places") @map("source_platform")
  leadScore          Int       @default(0) @map("lead_score")
  outreachStatus     String    @default("New") @map("outreach_status")
  outreachApproved   Boolean   @default(false) @map("outreach_approved")
  outreachApprovedAt DateTime? @map("outreach_approved_at")
  emailSent          Boolean   @default(false) @map("email_sent")
  whatsappSent       Boolean   @default(false) @map("whatsapp_sent")
  replied            Boolean   @default(false)
  lastContactedAt    DateTime? @map("last_contacted_at")
  nextFollowUpAt     DateTime? @map("next_follow_up_at")
  notes              String?
  rating             Float?
  reviewCount        Int?      @map("review_count")
  lastReviewAt       DateTime? @map("last_review_at")
  missingSeoMetadata Boolean   @default(false) @map("missing_seo_metadata")
  unsubscribed       Boolean   @default(false)
  doNotContact       Boolean   @default(false) @map("do_not_contact")
  archived           Boolean   @default(false)
  consentStatus      String    @default("legitimate_interest") @map("consent_status")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  regionRef       Region?        @relation(fields: [region], references: [name])
  contacts        LeadContact[]
  outreachLogs    OutreachLog[]
  inboxReplies    InboxReply[]
  aiReplyDrafts   AiReplyDraft[]
  notifications   Notification[]
  checklist       LeadChecklist?
  opportunities   Opportunity[]
  clientProjects  ClientProject[]
  callLogs        CallLog[]

  @@index([region])
  @@index([email])
  @@map("leads")
}

model CallLog {
  id              String    @id @default(cuid())
  leadId          String?   @map("lead_id")
  userId          String?   @map("user_id")
  contactName     String?   @map("contact_name")
  companyName     String?   @map("company_name")
  provider        String    @default("manual")
  providerCallSid String?   @unique @map("provider_call_sid")
  direction       String    @default("outbound")
  phone           String
  status          String    @default("planned")
  outcome         String?
  notes           String?
  durationSeconds Int       @default(0) @map("duration_seconds")
  startedAt       DateTime? @map("started_at")
  answeredAt      DateTime? @map("answered_at")
  endedAt         DateTime? @map("ended_at")
  followUpAt      DateTime? @map("follow_up_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  lead            Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
  @@index([userId])
  @@index([status])
  @@map("call_logs")
}

model ClientProject {
  id              String    @id @default(cuid())
  leadId          String?   @map("lead_id")
  clientUserId    String?   @map("client_user_id")
  employeeUserId  String?   @map("employee_user_id")
  companyName     String    @map("company_name")
  websiteUrl      String?   @map("website_url")
  gmbUrl          String?   @map("gmb_url")
  additionalWebsiteUrls String[] @default([]) @map("additional_website_urls")
  additionalGmbUrls     String[] @default([]) @map("additional_gmb_urls")
  status          String    @default("Onboarding")
  progress        Int       @default(0)
  estimatedMinutes Int      @default(0) @map("estimated_minutes")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  lead            Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  client          User?     @relation("ClientProjects", fields: [clientUserId], references: [id], onDelete: SetNull)
  employee        User?     @relation("EmployeeProjects", fields: [employeeUserId], references: [id], onDelete: SetNull)
  workLogs        WorkLog[]
  comments        ProjectComment[]
  milestones      ProjectMilestone[]
  snapshots       ProjectSnapshot[]
  weeklyReports   WeeklyReport[]

  @@index([leadId])
  @@index([clientUserId])
  @@index([employeeUserId])
  @@map("client_projects")
}

model ProjectComment {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  authorUserId String? @map("author_user_id")
  body        String
  type        String   @default("comment")
  approved    Boolean  @default(false)
  clientVisible Boolean @default(true) @map("client_visible")
  createdAt   DateTime @default(now()) @map("created_at")
  project     ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author      User?    @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([authorUserId])
  @@map("project_comments")
}

model ProjectMilestone {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  title       String
  description String?
  amount      Int      @default(0)
  status      String   @default("Pending")
  dueDate     DateTime? @map("due_date")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  project     ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_milestones")
}

model ProjectSnapshot {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  kind        String
  title       String
  summary     String
  metrics     Json     @default("{}")
  screenshotUrls Json  @default("[]") @map("screenshot_urls")
  createdAt   DateTime @default(now()) @map("created_at")
  project     ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_snapshots")
}

model WeeklyReport {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  weekStart   DateTime @map("week_start")
  weekEnd     DateTime @map("week_end")
  summary     String
  wins        Json     @default("[]")
  nextSteps   Json     @default("[]") @map("next_steps")
  totalMinutes Int    @default(0) @map("total_minutes")
  createdAt   DateTime @default(now()) @map("created_at")
  project     ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("weekly_reports")
}

model WorkLog {
  id            String   @id @default(cuid())
  projectId     String   @map("project_id")
  employeeUserId String? @map("employee_user_id")
  title         String
  summary       String
  changesMade   String   @map("changes_made")
  timeMinutes   Int      @default(0) @map("time_minutes")
  screenshotUrls Json    @default("[]") @map("screenshot_urls")
  clientVisible Boolean  @default(true) @map("client_visible")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  project       ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employee      User?    @relation("EmployeeWorkLogs", fields: [employeeUserId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([employeeUserId])
  @@map("work_logs")
}

model LeadChecklist {
  id                  String   @id @default(cuid())
  leadId              String   @unique @map("lead_id")
  websiteChecked      Boolean  @default(false) @map("website_checked")
  gbpChecked          Boolean  @default(false) @map("gbp_checked")
  reviewsChecked      Boolean  @default(false) @map("reviews_checked")
  contactFormChecked  Boolean  @default(false) @map("contact_form_checked")
  decisionMakerSearched Boolean @default(false) @map("decision_maker_searched")
  notes               String?
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  lead                Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_checklists")
}

model Opportunity {
  id          String   @id @default(cuid())
  leadId      String   @map("lead_id")
  title       String
  stage       String   @default("New")
  value       Int      @default(0)
  notes       String?
  nextActionAt DateTime? @map("next_action_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("opportunities")
}

model LeadContact {
  id        String   @id @default(cuid())
  leadId    String   @map("lead_id")
  type      String
  value     String
  status    String   @default("unverified")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_contacts")
}

model OutreachLog {
  id            String    @id @default(cuid())
  leadId        String    @map("lead_id")
  channel       String
  action        String
  status        String
  providerId    String?   @map("provider_id")
  message       String?
  metadata      Json?
  openedAt      DateTime? @map("opened_at")
  lastOpenedAt  DateTime? @map("last_opened_at")
  openCount     Int       @default(0) @map("open_count")
  clickedAt     DateTime? @map("clicked_at")
  lastClickedAt DateTime? @map("last_clicked_at")
  clickCount    Int       @default(0) @map("click_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  lead          Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("outreach_logs")
}

model ComposeEmailLog {
  id            String    @id @default(cuid())
  toEmail       String    @map("to_email")
  subject       String
  heading       String?
  status        String
  providerId    String?   @map("provider_id")
  message       String?
  metadata      Json?
  openedAt      DateTime? @map("opened_at")
  lastOpenedAt  DateTime? @map("last_opened_at")
  openCount     Int       @default(0) @map("open_count")
  clickedAt     DateTime? @map("clicked_at")
  lastClickedAt DateTime? @map("last_clicked_at")
  clickCount    Int       @default(0) @map("click_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([toEmail])
  @@map("compose_email_logs")
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String
  category  String
  subject   String
  body      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("email_templates")
}

model WhatsappTemplate {
  id           String   @id @default(cuid())
  name         String
  providerName String   @map("provider_name")
  language     String   @default("en")
  body         String
  approved     Boolean  @default(false)
  dailyCap      Int      @default(100)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("whatsapp_templates")
}

model InboxReply {
  id          String   @id @default(cuid())
  leadId      String?  @map("lead_id")
  fromEmail   String   @map("from_email")
  subject     String?
  body        String
  providerId  String?  @map("provider_id")
  receivedAt  DateTime @default(now()) @map("received_at")
  lead        Lead?    @relation(fields: [leadId], references: [id])

  @@map("inbox_replies")
}

model AiReplyDraft {
  id        String   @id @default(cuid())
  leadId    String   @map("lead_id")
  replyId   String?  @map("reply_id")
  draft     String
  status    String   @default("needs_review")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("ai_reply_drafts")
}

model AutomationRun {
  id           String    @id @default(cuid())
  region       String
  status       String
  startedAt    DateTime  @default(now()) @map("started_at")
  completedAt  DateTime? @map("completed_at")
  leadsFetched Int       @default(0) @map("leads_fetched")
  emailsSent   Int       @default(0) @map("emails_sent")
  whatsappSent Int       @default(0) @map("whatsapp_sent")
  failedCount  Int       @default(0) @map("failed_count")
  log          Json?

  @@map("automation_runs")
}

model Notification {
  id        String   @id @default(cuid())
  leadId    String?  @map("lead_id")
  recipientUserId String? @map("recipient_user_id")
  type      String
  title     String
  message   String
  actionUrl String?  @map("action_url")
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  recipient User?    @relation("UserNotifications", fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@index([recipientUserId, createdAt])
  @@map("notifications")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
